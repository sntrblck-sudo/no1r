{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "No1r Elevation",
  "type": "object",
  "required": ["summary","recommended_action","confidence","watch_items","audit_reference"],
  "properties": {
    "summary": {"type":"string"},
    "recommended_action": {"type":"string","enum":["post","edit_and_post","reject"]},
    "confidence": {"type":"number","minimum":0,"maximum":1},
    "watch_items": {"type":"array","items":{"type":"string"}},
    "audit_reference": {"type":"string"},
    "suggested_post_text": {"type":"string"}
  }
}
